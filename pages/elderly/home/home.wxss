.page-container,
.fullscreen-page {
  min-height: 100vh;
  background: var(--color-bg);
  color: var(--color-fg);
}

.page-container {
  display: flex;
  flex-direction: column;
  position: relative;
}

.fullscreen-page {
  display: flex;
  flex-direction: column;
}

.tab-content {
  flex: 1;
  min-height: 0;
}

.main-scroll {
  height: 100vh;
  padding: 112rpx 28rpx 196rpx;
  background: var(--color-bg);
}

.bp-scroll {
  padding-top: 40rpx;
}

.card {
  background: var(--color-surface);
  border: 2rpx solid var(--color-border);
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.home-header {
  display: grid;
  grid-template-columns: 82rpx 1fr auto;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 34rpx;
}

.brand-mark {
  width: 82rpx;
  height: 82rpx;
  border-radius: 22rpx;
  background: #08B765;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(8, 183, 101, 0.2);
}

.brand-copy {
  min-width: 0;
}

.brand-title {
  display: block;
  color: #111820;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.1;
}

.brand-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #717983;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.2;
}

.role-switch {
  height: 78rpx;
  padding: 6rpx;
  border: 2rpx solid #DADFE4;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  gap: 2rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.04);
}

.role-pill {
  min-width: 96rpx;
  height: 64rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #68717B;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1;
  white-space: nowrap;
}

.role-pill.active {
  background: #111820;
  color: #FFFFFF;
}

.hero-card {
  overflow: hidden;
  padding: 34rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #E9FFF0 0%, #FFFFFF 76%);
  border-color: #A9DDF4;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.04);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 28rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.eyebrow {
  display: block;
  color: var(--color-accent-dark);
  font-size: 25rpx;
  font-weight: 900;
}

.hero-title {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-top: 12rpx;
}

.streak-num {
  color: #111820;
  font-size: 72rpx;
  font-weight: 900;
  line-height: 1;
}

.streak-unit {
  color: var(--color-muted);
  font-size: 32rpx;
  font-weight: 700;
}

.hero-sub {
  display: block;
  margin-top: 16rpx;
  color: #717983;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.45;
}

.pillbox-visual {
  position: relative;
  flex-shrink: 0;
  width: 150rpx;
  height: 126rpx;
  border: 2rpx solid #9FD9F1;
  border-radius: 32rpx;
  background: #FFFFFF;
  box-shadow: inset 0 -24rpx 0 #DDF7E7, 0 10rpx 24rpx rgba(13, 158, 95, 0.08);
}

.pillbox-line {
  position: absolute;
  background: var(--color-border);
}

.pillbox-line.h1 {
  left: 20rpx;
  right: 20rpx;
  top: 34rpx;
  height: 2rpx;
}

.pillbox-line.h2 {
  left: 20rpx;
  right: 20rpx;
  bottom: 38rpx;
  height: 2rpx;
}

.pillbox-line.v1 {
  top: 18rpx;
  bottom: 18rpx;
  left: 50%;
  width: 2rpx;
}

.hero-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 34rpx;
}
.hero-actions .btn {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.btn {
  min-height: 96rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.3;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn.primary,
.take-btn,
.record-btn,
.profile-action,
.primary-btn {
  background: #06C46D;
  color: #FFFFFF;
  box-shadow: 0 10rpx 24rpx rgba(34, 197, 126, 0.18);
}

.btn.secondary,
.profile-action.secondary {
  background: #EEF0F2;
  color: var(--color-fg);
  box-shadow: none;
}

.section-title {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 24rpx;
  margin: 34rpx 4rpx 18rpx;
}

.section-heading {
  color: #111820;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.2;
}

.section-meta {
  color: var(--color-muted);
  font-size: 26rpx;
}

.dose-card {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 26rpx;
  align-items: center;
  padding: 34rpx 32rpx 32rpx;
  border-radius: 32rpx;
}

.time-badge {
  width: 136rpx;
  height: 136rpx;
  border-radius: 30rpx;
  background: #D9F8E2;
  color: #009C56;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1;
}

.dose-main {
  min-width: 0;
}

.dose-name {
  display: block;
  color: #111820;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.3;
  word-break: break-all;
}

.dose-desc {
  display: block;
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 28rpx;
}

.take-btn {
  grid-column: 1 / -1;
  width: 100%;
  min-height: 106rpx;
  margin-top: 10rpx;
  border-radius: 58rpx;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.3;
  display: flex;
  align-items: center;
  justify-content: center;
}

.all-done-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--color-accent-soft);
  border-color: #CFEFDD;
}

.done-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--color-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.done-text {
  color: var(--color-accent-dark);
  font-size: 34rpx;
  font-weight: 800;
}

.med-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.med-row {
  display: grid;
  grid-template-columns: 96rpx 1fr auto;
  gap: 22rpx;
  align-items: center;
  min-height: 146rpx;
  padding: 22rpx 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 30rpx;
  background: var(--color-surface);
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
}

.med-row.missed {
  background: #FFEAE8;
  border-color: #B9CFFF;
}

.med-row.done {
  background: var(--color-accent-soft);
  border-color: #CFEFDD;
}

.icon-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 26rpx;
  background: #EEF0F2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-circle.danger {
  background: #FFFFFF;
}

.icon-circle.ok {
  background: var(--color-accent);
}

.med-main {
  min-width: 0;
}

.med-name {
  display: block;
  color: #111820;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.3;
  word-break: break-all;
}

.med-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 26rpx;
  line-height: 1.35;
}

.chip {
  min-width: 94rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #F0F1F3;
  color: var(--color-muted);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
}

.chip.warn {
  width: auto;
  background: #FFFFFF;
  color: var(--color-danger);
}

.chip.ok {
  background: #FFFFFF;
  color: var(--color-accent-dark);
}

.message-card {
  display: grid;
  grid-template-columns: 88rpx 1fr auto;
  gap: 20rpx;
  align-items: center;
  margin-top: 28rpx;
}

.avatar,
.profile-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--color-blue-soft);
  color: var(--color-health-blue);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
}

.message-main {
  min-width: 0;
}

.message-meta {
  display: block;
  color: var(--color-muted);
  font-size: 24rpx;
}

.message-text {
  display: block;
  margin-top: 8rpx;
  color: var(--color-fg);
  font-size: 30rpx;
  line-height: 1.4;
}

.mini-btn {
  width: fit-content !important;
  display: flex;
  align-items: center;
  min-height: 64rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: var(--color-accent-soft);
  color: var(--color-accent-dark);
  font-size: 26rpx;
  font-weight: 700;
}

.bp-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.bp-title {
  color: var(--color-fg);
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.1;
}

.bp-subtitle {
  color: var(--color-muted);
  font-size: 26rpx;
}

.period-tabs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  padding: 8rpx;
  margin-bottom: 22rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 999rpx;
  background: var(--color-surface);
}

.period-tab {
  min-height: 70rpx;
  border-radius: 999rpx;
  color: var(--color-muted);
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
}

.period-tab.active {
  background: var(--color-accent);
  color: #FFFFFF;
}

.period-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.nav-arrow {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-surface);
  border: 2rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-arrow.disabled {
  opacity: 0.45;
}

.period-label {
  flex: 1;
  text-align: center;
  color: var(--color-fg);
  font-size: 30rpx;
  font-weight: 800;
}

.bp-summary {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.metric-card {
  min-height: 168rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--color-accent-soft);
  border: 2rpx solid #CFEFDD;
}

.metric-card.blue {
  background: var(--color-blue-soft);
  border-color: #D2E5F5;
}

.metric-label {
  display: block;
  color: var(--color-muted);
  font-size: 24rpx;
  font-weight: 700;
}

.metric-value {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-top: 14rpx;
  color: var(--color-fg);
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1;
}

.slash {
  color: var(--color-muted);
  font-size: 34rpx;
}

.metric-unit {
  display: block;
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 22rpx;
}

.bp-chart-card {
  padding-bottom: 24rpx;
}

.chart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.chart-title {
  color: var(--color-fg);
  font-size: 34rpx;
  font-weight: 800;
}

.chart-legend {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: var(--color-muted);
  font-size: 24rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-dot.sys {
  background: var(--color-accent);
}

.legend-dot.dia {
  background: var(--color-health-blue);
}

.bar-scroll {
  width: 100%;
  white-space: nowrap;
}

.bar-chart {
  height: 220rpx;
  min-width: 100%;
  display: flex;
  align-items: flex-end;
  gap: 24rpx;
  padding: 12rpx 4rpx 0;
}

.bar-group {
  width: 62rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.bar-pair {
  height: 124rpx;
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

.bar {
  width: 20rpx;
  min-height: 10rpx;
  border-radius: 999rpx 999rpx 6rpx 6rpx;
}

.bar.sys {
  background: var(--color-accent);
}

.bar.dia {
  background: var(--color-health-blue);
}

.bar-label {
  display: block;
  margin-top: 18rpx;
  color: var(--color-muted);
  font-size: 22rpx;
  line-height: 1.2;
}

.swipe-hint {
  display: block;
  margin-top: 12rpx;
  color: var(--color-muted);
  font-size: 22rpx;
  text-align: center;
}

.record-btn {
  width: 100%;
  min-height: 124rpx;
  margin: 24rpx 0 34rpx;
  padding: 24rpx 32rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  text-align: left;
}

.record-text {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.record-title {
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 800;
}

.record-desc {
  color: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
}

.recent-title {
  display: block;
  margin: 0 4rpx 18rpx;
  color: var(--color-fg);
  font-size: 34rpx;
  font-weight: 800;
}

.bp-record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 24rpx;
  background: var(--color-surface);
}

.bp-record-item.abnormal {
  background: var(--color-danger-soft);
  border-color: #F5CBD0;
}

.record-left {
  display: flex;
  align-items: baseline;
  min-width: 0;
}

.record-sys,
.record-dia {
  color: var(--color-fg);
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1;
}

.text-danger {
  color: var(--color-danger);
}

.record-sep {
  margin: 0 6rpx;
  color: var(--color-muted);
  font-size: 32rpx;
}

.record-unit {
  margin-left: 10rpx;
  color: var(--color-muted);
  font-size: 22rpx;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  flex-shrink: 0;
}

.record-date,
.record-hr {
  color: var(--color-muted);
  font-size: 24rpx;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.profile-avatar {
  background: var(--color-accent-soft);
  color: var(--color-accent-dark);
}

.profile-main {
  min-width: 0;
}

.profile-title {
  display: block;
  color: var(--color-fg);
  font-size: 38rpx;
  font-weight: 800;
}

.profile-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 26rpx;
}

.profile-action {
  width: 100%;
  min-height: 104rpx;
  margin-top: 24rpx;
  border-radius: 24rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.bottom-nav {
  grid-template-columns: repeat(3, 1fr);
}

/* BP record camera */
.bp-record-page {
  background: var(--color-bg);
}

.camera-header,
.bp-record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 144rpx;
  padding: 68rpx 32rpx 20rpx;
  background: var(--color-surface);
  border-bottom: 2rpx solid var(--color-border);
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.text-btn {
  min-width: 112rpx;
  min-height: 64rpx;
  color: var(--color-accent-dark);
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.header-title {
  color: var(--color-fg);
  font-size: 32rpx;
  font-weight: 800;
}

.placeholder-btn {
  width: 112rpx;
}

.bp-record-scroll {
  flex: 1;
  min-height: 0;
}

.bp-camera-panel {
  position: relative;
  height: 460rpx;
  background: #2D3238;
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-frame,
.bp-camera-frame {
  width: 520rpx;
  height: 280rpx;
  border: 4rpx solid var(--color-accent);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-hint,
.camera-done {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.hint-text {
  color: #D6DADE;
  font-size: 28rpx;
}

.camera-done-text {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
}

.retake-btn {
  color: #D6DADE;
  font-size: 24rpx;
  text-decoration: underline;
  display: flex;
  align-items: center;
}

.shutter-btn {
  position: absolute;
  left: 50%;
  bottom: 32rpx;
  width: 112rpx;
  height: 112rpx;
  margin-left: -56rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 8rpx solid var(--color-accent);
}

.bp-input-section {
  padding: 32rpx;
  background: var(--color-bg);
}

.bp-input-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.bp-input-item {
  min-width: 0;
  padding: 24rpx 16rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 24rpx;
  background: var(--color-surface);
}

.bp-input-label {
  display: block;
  margin-bottom: 8rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  text-align: center;
}

.bp-input {
  width: 100%;
  height: 64rpx;
  color: var(--color-fg);
  font-size: 40rpx;
  font-weight: 800;
  text-align: center;
}

.bp-input-help {
  display: block;
  margin-top: 20rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  text-align: center;
}

.bottom-bar {
  padding: 28rpx 32rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  background: var(--color-surface);
  border-top: 2rpx solid var(--color-border);
}

.primary-btn {
  width: 100%;
  min-height: 104rpx;
  border-radius: 26rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.primary-btn.disabled {
  background: #E4E6E9;
  color: var(--color-muted);
  box-shadow: none;
}

/* Success */
.success-section {
  flex: 1;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.success-icon {
  width: 168rpx;
  height: 168rpx;
  border-radius: 50%;
  background: var(--color-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 42rpx;
  box-shadow: 0 14rpx 32rpx rgba(34, 197, 126, 0.22);
}

.success-title {
  color: var(--color-fg);
  font-size: 46rpx;
  font-weight: 800;
  margin-bottom: 34rpx;
}

.success-detail-card {
  width: 100%;
  max-width: 560rpx;
  padding: 32rpx;
  margin-bottom: 42rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 28rpx;
  background: var(--color-surface);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.detail-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 18rpx;
  color: var(--color-muted);
  font-size: 28rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-value {
  color: var(--color-fg);
  font-weight: 800;
}
