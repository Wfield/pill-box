.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F7F8F9;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-top: 80rpx;
  background: #FFFFFF;
  border-bottom: 2rpx solid #E4E6E9;
  box-shadow: 0 4rpx 18rpx rgba(15, 23, 42, 0.05);
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0D9E5F;
  background: none;
  border: none;
  padding: 0;
  line-height: 1.5;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3238;
}

.add-btn {
  padding: 16rpx 24rpx;
  min-height: 72rpx;
  background: #22C57E;
  color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 8rpx;
  line-height: 1.5;
  box-shadow: 0 6rpx 16rpx rgba(34, 197, 126, 0.16);
}

.scroll-area {
  flex: 1;
  padding: 32rpx;
  padding-bottom: 172rpx;
  padding-bottom: calc(172rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(172rpx + env(safe-area-inset-bottom));
}

.med-item {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 36rpx;
  border: 2rpx solid #E4E6E9;
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.06);
}

.med-item-left {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: rgba(240, 168, 104, 0.2);
  color: #0D9E5F;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.med-icon {
  font-size: 52rpx;
}

.med-item-body {
  flex: 1;
  min-width: 0;
}

.med-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3238;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.3;
  word-break: break-all;
}

.med-dose {
  font-size: 28rpx;
  color: #7D848C;
  display: block;
  line-height: 1.45;
  word-break: break-all;
}

.med-time {
  font-size: 26rpx;
  color: #0D9E5F;
  display: block;
  margin-top: 8rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  background: #FFFFFF;
  border: 2rpx solid #E4E6E9;
  border-radius: 28rpx;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #7D848C;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 132rpx;
  height: calc(132rpx + constant(safe-area-inset-bottom));
  height: calc(132rpx + env(safe-area-inset-bottom));
  min-height: 132rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(253, 251, 247, 0.98);
  border-top: 2rpx solid #E4E6E9;
  box-shadow: 0 -8rpx 24rpx rgba(41, 37, 36, 0.06);
  display: flex;
  align-items: flex-start;
  z-index: 100;
}
