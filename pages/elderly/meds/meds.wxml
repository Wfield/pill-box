<view class="page-container">
  <view class="header">
    <button class="back-btn" bindtap="goBack">
      <icon name="chevronLeft" size="48" color="#E8924A" stroke="2.5" />
      <text>返回</text>
    </button>
    <text class="header-title">我的药盒</text>
    <button class="add-btn" bindtap="goToPhotoAdd">
      <icon name="camera" size="40" color="#FFFFFF" stroke="1.8" />
      <text>拍照添加</text>
    </button>
  </view>

  <scroll-view class="scroll-area" scroll-y>
    <view wx:for="{{medications}}" wx:for-item="med" wx:key="id" class="med-item">
      <view class="med-item-left">
        <icon name="pill" size="56" color="#E8924A" stroke="1.8" />
      </view>
      <view class="med-item-body">
        <text class="med-name">{{med.name}}</text>
        <text class="med-dose">每次 {{med.dose}} · {{med.note}}</text>
        <text class="med-time">每天 {{med.times[0] || med.time}}</text>
      </view>
    </view>

    <view wx:if="{{medications.length === 0}}" class="empty-state">
      <icon name="pillbox" size="120" color="#E8924A" stroke="2.5" />
      <text class="empty-text">药盒为空，点击右上角拍照添加药品</text>
    </view>
  </scroll-view>

  <view class="bottom-nav">
    <nav-item style="flex:1;min-width:0;display:block;" icon="home" label="今日用药" active="{{false}}" activeColor="#E8924A" bind:tap="goBack" />
    <nav-item style="flex:1;min-width:0;display:block;" icon="heart" label="血压" active="{{false}}" activeColor="#E8924A" bind:tap="goToBp" />
  </view>
</view>
