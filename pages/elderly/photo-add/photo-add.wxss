/* Shared */
.page-camera,
.page-recognize,
.page-times,
.page-success {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F7F8F9;
}

.page-camera {
  background: #1C1917;
  color: #FFFFFF;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  padding-top: 80rpx;
  background: #FFFFFF;
  border-bottom: 2rpx solid #E4E6E9;
  box-shadow: 0 4rpx 18rpx rgba(15, 23, 42, 0.05);
}

.spacer {
  width: 100rpx;
}

.back-btn {
  font-size: 28rpx;
  font-weight: 700;
  color: #0D9E5F;
  background: none;
  border: none;
  padding: 0;
  line-height: 1.5;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.top-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3238;
}

.primary-btn {
  width: 100%;
  min-height: 104rpx;
  padding: 36rpx;
  background: #22C57E;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
  border-radius: 28rpx;
  text-align: center;
  line-height: 1.5;
  box-shadow: 0 8rpx 20rpx rgba(34, 197, 126, 0.2);
}

.primary-btn.disabled {
  background: #E7E5E4;
  color: #7D848C;
}

.secondary-btn {
  width: 100%;
  min-height: 96rpx;
  padding: 28rpx;
  background: #E4E6E9;
  color: #7D848C;
  font-size: 32rpx;
  border-radius: 28rpx;
  text-align: center;
  line-height: 1.5;
}

/* Camera Step */
.camera-top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  padding-top: 80rpx;
}

.cancel-btn {
  font-size: 32rpx;
  color: #FFFFFF;
  background: none;
  border: none;
  padding: 0;
  line-height: 1.5;
}

.camera-title {
  font-size: 32rpx;
  font-weight: 700;
}

.camera-view {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.camera-guide {
  width: 100%;
  height: 400rpx;
  border: 4rpx solid #22C57E;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #7D848C;
  background: rgba(253, 251, 247, 0.04);
}

.guide-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.guide-text {
  font-size: 28rpx;
}

.camera-shutter-area {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}

.shutter {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 8rpx solid #22C57E;
}

.shutter-hint {
  text-align: center;
  font-size: 24rpx;
  color: #7D848C;
  padding-bottom: 32rpx;
}

/* Recognize Step */
.recognize-body {
  flex: 1;
  overflow: auto;
  padding: 40rpx;
}

.recognize-card {
  background: #FFFFFF;
  border: 2rpx solid #E4E6E9;
  border-radius: 28rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.photo-placeholder {
  background: #F5F5F4;
  border-radius: 20rpx;
  height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #E7E5E4;
  margin-bottom: 32rpx;
}

.photo-icon {
  font-size: 72rpx;
  color: #7D848C;
  margin-bottom: 8rpx;
}

.photo-label {
  font-size: 24rpx;
  color: #7D848C;
}

.recognize-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.badge-text {
  font-size: 28rpx;
  color: #0D9E5F;
  font-weight: 500;
}

.med-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #2D3238;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.25;
  word-break: break-all;
}

.confirm-question {
  font-size: 28rpx;
  color: #7D848C;
  display: block;
}

.bottom-actions {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* Times Step */
.times-body {
  flex: 1;
  overflow: auto;
  padding: 40rpx;
}

.times-hint {
  font-size: 28rpx;
  color: #7D848C;
  display: block;
  margin-bottom: 32rpx;
}

.time-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.time-option {
  width: 100%;
  min-height: 112rpx;
  padding: 36rpx;
  border-radius: 28rpx;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 48rpx;
  padding-right: 48rpx;
  border: 4rpx solid #E4E6E9;
  background: #FFFFFF;
  color: #2D3238;
  line-height: 1.5;
}

.time-option.selected {
  background: #22C57E;
  color: #FFFFFF;
  border-color: #22C57E;
}

.check-mark {
  font-size: 48rpx;
}

.bottom-bar {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #E4E6E9;
  background: #FFFFFF;
}

/* Success Step */
.page-success {
  background: #F7F8F9;
}

.success-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx;
}

.success-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #22C57E;
  color: #FFFFFF;
  font-size: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.success-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2D3238;
  margin-bottom: 24rpx;
}

.success-desc {
  font-size: 26rpx;
  color: #7D848C;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.summary-card {
  background: #FFFFFF;
  border: 2rpx solid #E4E6E9;
  border-radius: 20rpx;
  padding: 32rpx;
  width: 100%;
  max-width: 560rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #7D848C;
  margin-bottom: 12rpx;
}

.summary-row:last-child {
  margin-bottom: 0;
}

.summary-value {
  font-weight: 700;
  color: #2D3238;
}
