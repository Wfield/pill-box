/* Shared */
.page-camera,
.page-recognize,
.page-times,
.page-success {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #FAF6EE;
}

.page-camera {
  background: #1C1917;
  color: #FFFFFF;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  padding-top: 80rpx;
  background: #FDFBF7;
  border-bottom: 2rpx solid #F3EBDD;
}

.spacer {
  width: 100rpx;
}

.back-btn {
  font-size: 28rpx;
  font-weight: 700;
  color: #D97D38;
  background: none;
  border: none;
  padding: 0;
  line-height: 1.5;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.top-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #292524;
}

.primary-btn {
  width: 100%;
  padding: 36rpx;
  background: #E8924A;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
  border-radius: 28rpx;
  text-align: center;
  line-height: 1.5;
}

.primary-btn.disabled {
  background: #E7E5E4;
  color: #A8A29E;
}

.secondary-btn {
  width: 100%;
  padding: 28rpx;
  background: #F3EBDD;
  color: #78716C;
  font-size: 32rpx;
  border-radius: 28rpx;
  text-align: center;
  line-height: 1.5;
}

/* Camera Step */
.camera-top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  padding-top: 80rpx;
}

.cancel-btn {
  font-size: 32rpx;
  color: #FFFFFF;
  background: none;
  border: none;
  padding: 0;
  line-height: 1.5;
}

.camera-title {
  font-size: 32rpx;
  font-weight: 700;
}

.camera-view {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.camera-guide {
  width: 100%;
  height: 400rpx;
  border: 4rpx solid #F0A868;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #A8A29E;
}

.guide-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.guide-text {
  font-size: 28rpx;
}

.camera-shutter-area {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}

.shutter {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 8rpx solid #F0A868;
}

.shutter-hint {
  text-align: center;
  font-size: 24rpx;
  color: #A8A29E;
  padding-bottom: 32rpx;
}

/* Recognize Step */
.recognize-body {
  flex: 1;
  overflow: auto;
  padding: 40rpx;
}

.recognize-card {
  background: #FDFBF7;
  border: 2rpx solid #F3EBDD;
  border-radius: 28rpx;
  padding: 36rpx;
}

.photo-placeholder {
  background: #F5F5F4;
  border-radius: 20rpx;
  height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #E7E5E4;
  margin-bottom: 32rpx;
}

.photo-icon {
  font-size: 72rpx;
  color: #A8A29E;
  margin-bottom: 8rpx;
}

.photo-label {
  font-size: 24rpx;
  color: #A8A29E;
}

.recognize-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.badge-text {
  font-size: 28rpx;
  color: #D97D38;
  font-weight: 500;
}

.med-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #292524;
  display: block;
  margin-bottom: 12rpx;
}

.confirm-question {
  font-size: 28rpx;
  color: #78716C;
  display: block;
}

.bottom-actions {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* Times Step */
.times-body {
  flex: 1;
  overflow: auto;
  padding: 40rpx;
}

.times-hint {
  font-size: 28rpx;
  color: #78716C;
  display: block;
  margin-bottom: 32rpx;
}

.time-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.time-option {
  width: 100%;
  padding: 36rpx;
  border-radius: 28rpx;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 48rpx;
  padding-right: 48rpx;
  border: 4rpx solid #F3EBDD;
  background: #FDFBF7;
  color: #44403C;
  line-height: 1.5;
}

.time-option.selected {
  background: #E8924A;
  color: #FFFFFF;
  border-color: #E8924A;
}

.check-mark {
  font-size: 48rpx;
}

.bottom-bar {
  padding: 32rpx;
  border-top: 2rpx solid #F3EBDD;
  background: #FDFBF7;
}

/* Success Step */
.page-success {
  background: #FAF6EE;
}

.success-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx;
}

.success-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #E8924A;
  color: #FFFFFF;
  font-size: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.success-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #292524;
  margin-bottom: 24rpx;
}

.success-desc {
  font-size: 26rpx;
  color: #78716C;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.summary-card {
  background: #FDFBF7;
  border: 2rpx solid #F3EBDD;
  border-radius: 20rpx;
  padding: 32rpx;
  width: 100%;
  max-width: 560rpx;
  margin-bottom: 40rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #78716C;
  margin-bottom: 12rpx;
}

.summary-row:last-child {
  margin-bottom: 0;
}

.summary-value {
  font-weight: 700;
  color: #292524;
}
