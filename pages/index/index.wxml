<view class="page-wrapper">
  <view class="content">
    <view class="logo-section">
      <icon class="logo-icon" name="pillbox" size="120" color="#E8924A" stroke="2.5" />
      <text class="logo-title">智能药盒</text>
      <text class="logo-subtitle">请选择您的角色</text>
    </view>

    <view class="role-section">
      <view class="role-card elderly" bindtap="goToElderly">
        <view class="role-icon-wrap">
          <icon name="user" size="80" color="#E8924A" stroke="1.8" />
        </view>
        <text class="role-name">我为自己使用</text>
        <text class="role-desc">管理自己的用药和健康</text>
      </view>

      <view class="role-card child" bindtap="goToChild">
        <view class="role-icon-wrap">
          <icon name="user" size="80" color="#D97D38" stroke="1.8" />
        </view>
        <text class="role-name">我帮家人管理</text>
        <text class="role-desc">远程关注老人的用药情况</text>
      </view>
    </view>

    <text class="footer-text">智能药盒 MVP · v1.0.0</text>
  </view>
</view>
