.page-wrapper {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 56rpx 48rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F7F8F9 58%, #E4E6E9 100%);
}

.content {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-section {
  text-align: center;
  margin-bottom: 64rpx;
}

.logo-icon {
  display: block;
  margin: 0 auto 24rpx;
}

.logo-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #2D3238;
  display: block;
  margin-bottom: 12rpx;
}

.logo-subtitle {
  font-size: 28rpx;
  color: #7D848C;
}

.role-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  margin-bottom: 80rpx;
}

.role-card {
  width: 100%;
  min-height: 224rpx;
  padding: 44rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
  transition: transform 0.2s;
  cursor: pointer;
}

.role-card:active {
  transform: scale(0.97);
}

.role-card.elderly {
  background: linear-gradient(135deg, #FFFFFF, #F7F8F9);
  border: 2rpx solid #E4E6E9;
}

.role-card.child {
  background: linear-gradient(135deg, #FFF8F0, #F7F8F9);
  border: 2rpx solid #F0B47B;
}

.role-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
}

.role-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3238;
}

.role-desc {
  font-size: 26rpx;
  color: #7D848C;
  text-align: center;
  line-height: 1.45;
}

.footer-text {
  font-size: 22rpx;
  color: #7D848C;
}
