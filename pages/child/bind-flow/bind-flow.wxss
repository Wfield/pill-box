.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F7F8F9;
}

.top-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-top: 80rpx;
  background: #FFFFFF;
  border-bottom: 2rpx solid #E4E6E9;
  box-shadow: 0 4rpx 18rpx rgba(15, 23, 42, 0.05);
}

.back-btn {
  font-size: 32rpx;
  color: #7D848C;
  background: none;
  border: none;
  padding: 0;
  line-height: 1.5;
  min-width: 64rpx;
  min-height: 64rpx;
}

.page-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3238;
}

.step-content {
  flex: 1;
  overflow: auto;
  padding: 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.step-content.centered {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.step-icon-section {
  text-align: center;
  margin-bottom: 48rpx;
}

.step-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(240, 168, 104, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin: 0 auto 24rpx;
}

.step-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3238;
  display: block;
  margin-bottom: 12rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #7D848C;
  display: block;
  line-height: 1.5;
}

.input-card {
  background: #FFFFFF;
  border: 2rpx solid #E4E6E9;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.06);
}

.input-label {
  font-size: 26rpx;
  color: #7D848C;
  display: block;
  margin-bottom: 16rpx;
}

.phone-input {
  width: 100%;
  font-size: 44rpx;
  font-weight: 700;
  color: #2D3238;
  background: transparent;
  border-bottom: 4rpx solid #22C57E;
  padding-bottom: 12rpx;
  letter-spacing: 2rpx;
  min-height: 88rpx;
}

.nickname-input {
  width: 100%;
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3238;
  background: transparent;
  border-bottom: 4rpx solid #22C57E;
  padding-bottom: 12rpx;
  min-height: 88rpx;
}

.primary-btn {
  width: 100%;
  min-height: 104rpx;
  padding: 36rpx;
  background: #22C57E;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
  border-radius: 28rpx;
  text-align: center;
  margin-top: 32rpx;
  line-height: 1.5;
  box-shadow: 0 8rpx 20rpx rgba(34, 197, 126, 0.2);
}

/* Waiting */
.waiting-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(240, 168, 104, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  margin-bottom: 40rpx;
}

.waiting-desc {
  font-size: 28rpx;
  color: #7D848C;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.tip-card {
  background: #FFFFFF;
  border: 2rpx solid #E4E6E9;
  border-radius: 20rpx;
  padding: 24rpx;
  font-size: 24rpx;
  color: #7D848C;
  margin-bottom: 48rpx;
  text-align: left;
  line-height: 1.5;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
}

/* Success */
.success-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #22C57E;
  color: #FFFFFF;
  font-size: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.success-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2D3238;
  margin-bottom: 16rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #7D848C;
  text-align: center;
  margin-bottom: 48rpx;
}
