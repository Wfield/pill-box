<view class="page-container">
  <view class="top-bar">
    <button class="back-btn" bindtap="goBack">
      <icon name="chevronLeft" size="48" color="#7D848C" stroke="2.5" />
    </button>
    <text class="page-title">绑定老人</text>
  </view>

  <!-- Step 0: Input phone -->
  <view wx:if="{{step === 0}}" class="step-content">
    <view class="step-icon-section">
      <view class="step-icon">
        <icon name="user" size="72" color="#22C57E" stroke="1.8" />
      </view>
      <text class="step-title">输入老人的手机号</text>
      <text class="step-desc">老人需先安装此 App 并选择"为自己使用"</text>
    </view>
    <view class="input-card">
      <text class="input-label">老人手机号码</text>
      <input class="phone-input" type="tel" placeholder="请输入11位手机号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
    </view>
    <view class="input-card">
      <text class="input-label">称呼（如：妈妈/爸爸/奶奶）</text>
      <input class="nickname-input" type="text" placeholder="给老人起个称呼" value="{{nickname}}" bindinput="onNicknameInput" maxlength="10" />
    </view>
    <button class="primary-btn" bindtap="sendInvite">发送绑定邀请</button>
  </view>

  <!-- Step 1: Waiting -->
  <view wx:elif="{{step === 1}}" class="step-content centered">
    <view class="waiting-icon anim-pulse">
      <icon name="bell" size="80" color="#22C57E" stroke="1.8" />
    </view>
    <text class="step-title">等待老人确认</text>
    <text class="waiting-desc">已向老人手机发送绑定邀请，老人在 App 内点击"同意"后即绑定成功</text>
    <view class="tip-card">
      <text>💡 如果老人不会操作，可以拿过老人的手机帮 TA 点"同意"</text>
    </view>
    <button class="primary-btn" bindtap="simulateConfirm">模拟老人已确认</button>
  </view>

  <!-- Step 2: Success -->
  <view wx:elif="{{step === 2}}" class="step-content centered">
    <view class="success-icon anim-pop">
      <icon name="check" size="112" color="#FFFFFF" stroke="3" />
    </view>
    <text class="success-title">绑定成功</text>
    <text class="success-desc">接下来可以为老人添加药品和设置用药提醒</text>
    <button class="primary-btn" bindtap="finish">返回首页</button>
  </view>
</view>
