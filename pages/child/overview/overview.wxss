.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F7F8F9;
}

.header {
  padding: 24rpx 40rpx;
  padding-top: 80rpx;
  background: #FFFFFF;
  border-bottom: 2rpx solid #E4E6E9;
  box-shadow: 0 4rpx 18rpx rgba(15, 23, 42, 0.05);
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-date {
  font-size: 22rpx;
  color: #7D848C;
}

.settings-btn {
  font-size: 36rpx;
  color: #57534E;
  background: none;
  border: none;
  padding: 8rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.scroll-area {
  flex: 1;
  padding: 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* Alert Card */
.alert-card {
  border-radius: 28rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #FCE8EA, #FCE8EA);
  border: 4rpx solid #FDA4AF;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(225, 29, 72, 0.1);
}

.alert-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.alert-icon {
  font-size: 36rpx;
}

.alert-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #DC3545;
}

.alert-time {
  margin-left: auto;
  font-size: 22rpx;
  color: #FB7185;
}

.alert-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 12rpx 0;
}

.alert-med-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(244, 63, 94, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.alert-text {
  flex: 1;
  min-width: 0;
}

.alert-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #2D3238;
  display: block;
  line-height: 1.4;
  word-break: break-all;
}

.alert-med-name {
  font-size: 20rpx;
  color: #7D848C;
  display: block;
  word-break: break-all;
}

.alert-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.alert-btn {
  flex: 1;
  min-height: 88rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  line-height: 1.5;
}

.alert-btn.primary {
  background: #DC3545;
  color: #FFFFFF;
}

.alert-btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.congrats-card {
  border-radius: 28rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #22C57E, #0D9E5F);
  color: #FFFFFF;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(13, 158, 95, 0.16);
}

.congrats-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.congrats-title {
  font-size: 28rpx;
  font-weight: 700;
}

.congrats-desc {
  font-size: 24rpx;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.congrats-btn {
  width: 100%;
  min-height: 88rpx;
  padding: 24rpx;
  background: #FFFFFF;
  color: #DC3545;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.bind-btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.alert-btn.secondary {
  background: #E4E6E9;
  color: #57534E;
}

.like-sent-card {
  border-radius: 20rpx;
  padding: 20rpx;
  background: rgba(240, 168, 104, 0.15);
  color: #0D9E5F;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

/* Elder Card */
.elder-card {
  width: 100%;
  border-radius: 28rpx;
  padding: 32rpx;
  background: #FFFFFF;
  border: 2rpx solid #E4E6E9;
  margin-bottom: 20rpx;
  text-align: left;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.06);
}

.elder-card:active {
  transform: scale(0.99);
}

.elder-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.elder-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.elder-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(240, 168, 104, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.elder-meta {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.elder-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D3238;
  line-height: 1.3;
}

.elder-status {
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.elder-status.warn {
  color: #DC3545;
  font-weight: 700;
}

.elder-status.ok {
  color: #22C57E;
}

.arrow-icon {
  font-size: 36rpx;
  color: #D6D3D1;
}

.elder-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.stat-box {
  background: #F7F8F9;
  border-radius: 16rpx;
  padding: 20rpx;
  min-width: 0;
}

.stat-label {
  font-size: 22rpx;
  color: #7D848C;
  display: block;
  margin-bottom: 8rpx;
}

.stat-value {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stat-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D3238;
  line-height: 1.3;
  word-break: break-all;
}

.stat-num.done {
  color: #0D9E5F;
}

.stat-num.abnormal {
  color: #DC3545;
  background: #FCE8EA;
  border-radius: 12rpx;
  padding: 4rpx 8rpx;
}

.stat-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: #22C57E;
  color: #FFFFFF;
  border-radius: 8rpx;
}

/* Bind Button */
.bind-btn {
  width: 100%;
  min-height: 104rpx;
  padding: 28rpx;
  border: 4rpx dashed #D6D3D1;
  border-radius: 28rpx;
  color: #7D848C;
  font-size: 28rpx;
  background: none;
  text-align: center;
  line-height: 1.5;
}
