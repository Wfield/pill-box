page {
  /* 颜色系统 */
  --color-bg: #F7F8F9;
  --color-surface: #FFFFFF;
  --color-fg: #2D3238;
  --color-muted: #7D848C;
  --color-border: #E4E6E9;
  --color-accent: #22C57E;
  --color-accent-dark: #0D9E5F;
  --color-accent-soft: #E8F8EE;
  --color-health-blue: #5B9BD5;
  --color-blue-soft: #EBF3FA;
  --color-warn: #E8A838;
  --color-warn-soft: #FCF6E8;
  --color-danger: #DC3545;
  --color-danger-soft: #FCE8EA;
  --color-white: #FFFFFF;
  --color-black: #000000;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 40rpx;
  --spacing-2xl: 48rpx;

  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-full: 9999rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  --shadow-card: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
  --shadow-action: 0 8rpx 20rpx rgba(34, 197, 126, 0.2);

  /* 字体 */
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-base: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-2xl: 44rpx;
  --font-3xl: 52rpx;
  --font-4xl: 60rpx;

  /* 触控 */
  --touch-md: 88rpx;
  --touch-lg: 104rpx;
}
