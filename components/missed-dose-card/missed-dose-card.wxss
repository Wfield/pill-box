.card-container {
  border-radius: 28rpx;
  padding: 32rpx;
  background-color: #FCE8EA;
  border: 3rpx solid #F5CBD0;
  box-shadow: 0 8rpx 24rpx rgba(220, 53, 69, 0.08);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.time-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #DC3545;
  min-width: 0;
}

.missed-badge {
  margin-left: auto;
  font-size: 22rpx;
  font-weight: 500;
  padding: 8rpx 20rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  color: #DC3545;
}

.med-section {
  margin-bottom: 24rpx;
}

.med-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #2D3238;
  display: block;
  line-height: 1.25;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.med-detail {
  font-size: 24rpx;
  color: #7D848C;
}

.makeup-btn,
.done-btn {
  width: 100%;
  min-height: 96rpx;
  padding: 24rpx 32rpx;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 28rpx;
  line-height: 1.5;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.makeup-btn {
  background-color: #DC3545;
  color: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(220, 53, 69, 0.16);
}

.done-btn {
  background-color: #7D848C;
  color: #FFFFFF;
}

.anim-pop {
  animation: popIn 400ms ease-out forwards;
  display: inline-block;
}
