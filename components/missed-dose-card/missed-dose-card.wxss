.card-container {
  border-radius: 28rpx;
  padding: 32rpx;
  background-color: #F5F5F4;
  border: 2rpx solid #E7E5E4;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.time-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #78716C;
  min-width: 0;
}

.missed-badge {
  margin-left: auto;
  font-size: 22rpx;
  font-weight: 500;
  padding: 8rpx 20rpx;
  background-color: #E7E5E4;
  border-radius: 12rpx;
  color: #78716C;
}

.med-section {
  margin-bottom: 24rpx;
}

.med-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #44403C;
  display: block;
  line-height: 1.25;
  margin-bottom: 8rpx;
}

.med-detail {
  font-size: 24rpx;
  color: #78716C;
}

.makeup-btn,
.done-btn {
  width: 100%;
  min-height: 96rpx;
  padding: 24rpx 32rpx;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 28rpx;
  line-height: 1.5;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.makeup-btn {
  background-color: #D6D3D1;
  color: #44403C;
}

.done-btn {
  background-color: #A8A29E;
  color: #FFFFFF;
}

.anim-pop {
  animation: popIn 400ms ease-out forwards;
  display: inline-block;
}
