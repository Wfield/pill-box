<button class="take-btn {{done ? 'done' : 'ready'}} {{large ? 'large' : ''}}" disabled="{{animating}}" bindtap="handleTake">
  <view class="ripple-bg" wx:if="{{animating}}"></view>
  <view wx:if="{{done}}" class="btn-content anim-pop">
    <icon name="check" size="{{large ? 72 : 56}}" color="#FFFFFF" stroke="3" />
    <text>已记录</text>
  </view>
  <view wx:else class="btn-content">
    <icon name="check" size="{{large ? 72 : 56}}" color="#FFFFFF" stroke="2.5" />
    <text>我吃了</text>
  </view>
</button>
