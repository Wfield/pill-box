@import './styles/variables.wxss';
@import './styles/animations.wxss';

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-color: var(--color-bg);
  color: var(--color-fg);
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-tap-highlight-color: transparent;
  box-sizing: border-box;
}

view,
scroll-view,
swiper,
button,
text,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  border-radius: 0;
  line-height: 1.5;
}

button::after {
  content: none;
  border: none;
}

.bottom-nav {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 18rpx;
  bottom: calc(0rpx + constant(safe-area-inset-bottom));
  bottom: calc(0rpx + env(safe-area-inset-bottom));
  height: 124rpx;
  min-height: 124rpx;
  padding: 8rpx 10rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid var(--color-border);
  border-radius: 999rpx;
  box-shadow: 0 -4rpx 22rpx rgba(15, 23, 42, 0.08);
  display: flex;
  align-items: center;
  z-index: 100;
  backdrop-filter: blur(12rpx);
}

.with-bottom-nav {
  padding-bottom: 172rpx;
  padding-bottom: calc(172rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(172rpx + env(safe-area-inset-bottom));
}

.safe-scroll-bottom {
  padding-bottom: 172rpx;
  padding-bottom: calc(172rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(172rpx + env(safe-area-inset-bottom));
}

.safe-action-bottom {
  padding-bottom: 32rpx;
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}
